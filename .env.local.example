# ── Replicate ─────────────────────────────────────────────────────────────────
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret key: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret: https://dashboard.stripe.com/webhooks
# For local testing get this from: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Printify ───────────────────────────────────────────────────────────────────
# Personal access token: https://printify.com/app/account/connections
PRINTIFY_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your shop ID — find it at: GET https://api.printify.com/v1/shops.json
PRINTIFY_SHOP_ID=12345678

# Optional: override product IDs without redeploying
# Defaults: blueprint 91 (Framed Matte Poster), provider 9 (MWW), variant 45654 (8×10 black frame)
# PRINTIFY_BLUEPRINT_ID=91
# PRINTIFY_PROVIDER_ID=9
# PRINTIFY_VARIANT_ID=45654
